{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SVG LoRA paired evaluation results v2",
  "type": "object",
  "required": ["schema_version", "environment", "model", "decoding", "counts", "summary", "samples"],
  "properties": {
    "schema_version": {"const": 2},
    "environment": {"type": "object"},
    "model": {"type": "object", "required": ["base_path", "adapter_path"]},
    "decoding": {"type": "object", "required": ["do_sample", "num_beams", "max_new_tokens", "seed"]},
    "counts": {"type": "object", "required": ["validation_samples"]},
    "summary": {
      "type": "object",
      "required": ["base", "tuned"],
      "additionalProperties": {"$ref": "#/$defs/summary"}
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prompt", "reference_svg", "base", "tuned"],
        "properties": {
          "base": {"$ref": "#/$defs/output"},
          "tuned": {"$ref": "#/$defs/output"}
        }
      }
    }
  },
  "$defs": {
    "output": {
      "type": "object",
      "required": ["raw_text", "svg", "reward", "passes"],
      "properties": {
        "passes": {
          "type": "object",
          "required": ["valid", "quality"],
          "properties": {"valid": {"type": "boolean"}, "quality": {"type": "boolean"}}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "validity", "fidelity", "fatal_rate", "pass_rate", "valid_pass_rate", "quality_pass_rate"]
    }
  }
}
